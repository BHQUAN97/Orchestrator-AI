# ============================================
# AI Orchestrator v2.1 — API Keys + Ports
# Copy file nay thanh .env va dien key vao
# ============================================

# --- LiteLLM Master Key (tu dat, dung cho xac thuc) ---
LITELLM_MASTER_KEY=sk-master-change-me

# --- Model Providers (dien key khi co) ---
# BAT BUOC: OpenRouter (1 key, 200+ models) — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# BAT BUOC: Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Ports (dai 5000) ---
HERMES_PORT=5000
WEBUI_PORT=5001
LITELLM_PORT=5002
ORCHESTRATOR_PORT=5003
ANALYTICS_PORT=5004
GATEWAY_PORT=5005

# --- Gateway Login ---
# Tai khoan dang nhap portal (thay doi truoc khi deploy!)
AUTH_USERNAME=admin
AUTH_PASSWORD=admin
# Secret key cho token — BAT BUOC thay doi trong production
JWT_SECRET=orcai-dev-secret-change-me
# Domain cho cookie (de trong = auto detect)
COOKIE_DOMAIN=

# --- Cloudflare Tunnel ---
# Token lay tu Cloudflare Zero Trust dashboard
# Setup: scripts/tunnel-setup.bat
CLOUDFLARE_TUNNEL_TOKEN=

# --- Security ---
# API secret key — BAT BUOC trong production, dung cho xac thuc internal
API_SECRET=
# Origins duoc phep truy cap API (cach nhau bang dau phay)
ALLOWED_ORIGINS=http://localhost:5001,http://localhost:5003,https://ai.remoteterminal.online
# Gioi han request moi phut (rate limiting)
RATE_LIMIT=60
# Moi truong chay: development hoac production
NODE_ENV=development

# --- Budget ---
DAILY_BUDGET=2.00

# === Hybrid Local/Cloud ===
# Route task re (docs, scan) qua local model (LM Studio / Ollama)
# PREFER_LOCAL=true
# LOCAL_MODEL_URL=http://localhost:1234/v1
