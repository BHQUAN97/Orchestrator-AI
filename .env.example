# ============================================
# AI Orchestrator — API Keys Config
# Copy file nay thanh .env va dien key vao
# ============================================

# --- LiteLLM Master Key (tu dat, dung dang nhap dashboard) ---
LITELLM_MASTER_KEY=sk-master-change-me

# --- Model Providers (dien key khi co) ---
# Uu tien 1: OpenRouter (1 key, 200+ models) — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Uu tien 2: Kimi / Moonshot — https://platform.moonshot.cn/console/api-keys
KIMI_API_KEY=

# Uu tien 3: Anthropic (Claude Sonnet) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Uu tien 4: Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Uu tien 5: DeepSeek — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# --- Optional: Observability ---
# Langfuse (optional, cho detailed analytics) — https://langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001

# --- Ports ---
LITELLM_PORT=4001
LITELLM_UI_PORT=4000
HERMES_PORT=3000
